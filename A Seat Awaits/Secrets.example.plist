<?xml version="1.0" encoding="UTF-8"?>
<!--
  Copy this file to `Secrets.plist` (same folder) and fill in real values.
  `Secrets.plist` is gitignored so environment-specific config stays out of
  source control. Only the Supabase URL and the public anon key belong here;
  never put the service-role key or any server secret in the app bundle.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>SUPABASE_URL</key>
	<string>https://YOUR-PROJECT-ref.supabase.co</string>
	<key>SUPABASE_ANON_KEY</key>
	<string>YOUR_PUBLIC_ANON_KEY</string>
	<!--
	  Optional. Public origin used to build guest-facing share links such as
	  the QR code's `/r/{token}` URL. Defaults to https://aseatawaits.com when
	  omitted. NOT used to call any server API — only to construct URLs. Point
	  it at a staging origin for dev builds if needed.
	-->
	<key>PUBLIC_SITE_URL</key>
	<string>https://aseatawaits.com</string>
</dict>
</plist>
