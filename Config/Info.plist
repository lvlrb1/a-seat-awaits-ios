<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Partial Info.plist merged with the generated one (GENERATE_INFOPLIST_FILE=YES).
	  Registers the custom URL scheme used to deep-link into the app — primarily a
	  dev/testing affordance (e.g. `xcrun simctl openurl booted "aseatawaits://…"`)
	  to exercise DeepLinkRouter + ResetPasswordView without universal links.
	-->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>heartlineeventsolutionsllc.A-Seat-Awaits</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>aseatawaits</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
