<?xml version="1.0" encoding="UTF-8"?>
<!--
  TEMPLATE — copy to `Secrets.Production.plist` (same folder) and fill in the
  PRODUCTION Supabase project values. `Secrets.Production.plist` is gitignored
  so environment-specific config stays out of source control.

  Only the Supabase URL and the PUBLIC anon key belong here. The anon key is a
  public client credential; row-level security (RLS) is the security boundary.
  NEVER put the service-role key, a Stripe secret, or any server credential here.

  The "Embed Environment Secrets" build phase copies the file named by the
  SECRETS_FILE build setting (see Config/Production.xcconfig) into the app
  bundle as `Secrets.plist`, which AppConfig reads at runtime.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>SUPABASE_URL</key>
	<string>https://YOUR-PROD-PROJECT-ref.supabase.co</string>
	<key>SUPABASE_ANON_KEY</key>
	<string>YOUR_PROD_PUBLIC_ANON_KEY</string>
	<!-- Production guest-link origin. -->
	<key>PUBLIC_SITE_URL</key>
	<string>https://aseatawaits.com</string>
</dict>
</plist>
